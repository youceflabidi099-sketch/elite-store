<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Elite Star</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap');

:root {
  --gold: #F0C040;
  --gold2: #FFD700;
  --orange: #FF8C00;
  --purple: #8B5CF6;
  --bg: #080810;
  --bg2: #0D0D1A;
  --card: rgba(255,255,255,0.04);
  --card2: rgba(255,255,255,0.07);
  --border: rgba(255,255,255,0.07);
  --border2: rgba(240,192,64,0.3);
  --text: #F0F0FF;
  --muted: rgba(240,240,255,0.45);
  --muted2: rgba(240,240,255,0.25);
  --radius: 18px;
  --radius-sm: 12px;
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

body {
  font-family:'Tajawal',sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  padding-bottom: 90px;
}

/* BACKGROUND GLOW */
body::before {
  content:'';
  position:fixed;
  top:-200px; left:50%;
  transform:translateX(-50%);
  width:600px; height:600px;
  background: radial-gradient(circle, rgba(240,192,64,0.06) 0%, transparent 70%);
  pointer-events:none; z-index:0;
}
body::after {
  content:'';
  position:fixed;
  bottom:-100px; right:-100px;
  width:400px; height:400px;
  background: radial-gradient(circle, rgba(139,92,246,0.05) 0%, transparent 70%);
  pointer-events:none; z-index:0;
}

/* PAGES */
.page { display:none; position:relative; z-index:1; animation:fadeIn .25s ease; }
.page.active { display:block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

/* ========= NAV ========= */
.nav {
  position:fixed; bottom:0; left:0; right:0; z-index:200;
  background: rgba(8,8,16,0.92);
  backdrop-filter: blur(20px);
  border-top: 1px solid var(--border);
  display:flex; padding: 8px 0 calc(8px + env(safe-area-inset-bottom));
}
.nav-btn {
  flex:1; background:none; border:none; color:var(--muted);
  font-size:10px; font-family:'Tajawal',sans-serif; font-weight:500;
  cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:4px;
  transition:color .2s; padding:4px 0;
}
.nav-btn .ni { font-size:20px; transition:transform .2s; }
.nav-btn.active { color:var(--gold); }
.nav-btn.active .ni { transform:scale(1.15); }
.nav-indicator {
  position:absolute; top:0; left:0; right:0;
  height:1.5px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  opacity:0; transition:opacity .3s;
}
.nav.has-active .nav-indicator { opacity:1; }

/* ========= HEADER ========= */
.hero-header {
  padding: 32px 20px 20px;
  text-align:center;
  position:relative;
}
.hero-glow {
  position:absolute; top:0; left:50%; transform:translateX(-50%);
  width:300px; height:150px;
  background: radial-gradient(ellipse, rgba(240,192,64,0.12) 0%, transparent 70%);
  pointer-events:none;
}
.logo-wrap {
  display:inline-flex; align-items:center; justify-content:center;
  width:72px; height:72px; border-radius:22px;
  background: linear-gradient(135deg, rgba(240,192,64,0.15), rgba(255,140,0,0.08));
  border: 1px solid rgba(240,192,64,0.2);
  font-size:36px; margin-bottom:14px;
  box-shadow: 0 8px 32px rgba(240,192,64,0.1);
}
.hero-title {
  font-size:26px; font-weight:900; letter-spacing:-0.5px;
  background: linear-gradient(135deg, #FFD700, #F0C040, #FF8C00);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  margin-bottom:6px;
}
.hero-sub { font-size:13px; color:var(--muted); font-weight:400; }

/* ========= SECTION LABEL ========= */
.sec-label {
  font-size:11px; font-weight:700; color:var(--muted2);
  text-transform:uppercase; letter-spacing:1.5px;
  padding: 0 20px; margin:20px 0 10px;
  display:flex; align-items:center; gap:8px;
}
.sec-label::after { content:''; flex:1; height:1px; background:var(--border); }

/* ========= PACKAGE CARDS ========= */
.pkg-list { padding:0 16px; display:flex; flex-direction:column; gap:10px; }

.pkg-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  cursor:pointer;
  transition: all .25s cubic-bezier(.4,0,.2,1);
  position:relative; overflow:hidden;
  display:flex; align-items:center; gap:14px;
}
.pkg-card::before {
  content:'';
  position:absolute; inset:0;
  background: linear-gradient(135deg, rgba(240,192,64,0.04), transparent);
  opacity:0; transition:opacity .25s;
}
.pkg-card:active { transform:scale(.97); }
.pkg-card.selected {
  border-color: rgba(240,192,64,0.5);
  background: rgba(240,192,64,0.06);
  box-shadow: 0 0 0 1px rgba(240,192,64,0.15), 0 8px 24px rgba(240,192,64,0.08);
}
.pkg-card.selected::before { opacity:1; }

.pkg-badge {
  position:absolute; top:0; left:16px;
  font-size:9px; font-weight:800; letter-spacing:.5px;
  padding:3px 9px; border-radius:0 0 8px 8px; text-transform:uppercase;
}
.badge-hot { background:linear-gradient(135deg,#FF4757,#FF6B81); color:#fff; }
.badge-best { background:linear-gradient(135deg,var(--gold),var(--orange)); color:#1a1a1a; }
.badge-vip { background:linear-gradient(135deg,#8B5CF6,#6366F1); color:#fff; }

.pkg-icon-wrap {
  width:52px; height:52px; border-radius:15px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center; font-size:26px;
  background: rgba(255,255,255,0.05); border:1px solid var(--border);
  transition:transform .2s;
}
.pkg-card.selected .pkg-icon-wrap { transform:scale(1.05); }

.pkg-info { flex:1; min-width:0; }
.pkg-name { font-size:15px; font-weight:700; margin-bottom:3px; }
.pkg-desc { font-size:12px; color:var(--muted); }

.pkg-right { text-align:left; flex-shrink:0; }
.pkg-price { font-size:18px; font-weight:900; color:var(--gold); line-height:1; }
.pkg-old { font-size:11px; color:var(--muted2); text-decoration:line-through; margin-bottom:2px; }
.pkg-save { font-size:10px; color:#4ade80; font-weight:700; margin-top:2px; }

.pkg-check {
  position:absolute; top:12px; left:12px;
  width:20px; height:20px; border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--orange));
  display:none; align-items:center; justify-content:center;
  font-size:11px; box-shadow:0 2px 8px rgba(240,192,64,0.4);
}
.pkg-card.selected .pkg-check { display:flex; }

/* ========= ORDER SUMMARY ========= */
.summary-wrap { padding:0 16px; margin-top:16px; }
.summary-box {
  background: var(--card2);
  border:1px solid var(--border2);
  border-radius:var(--radius);
  overflow:hidden;
}
.summary-head {
  padding:14px 16px;
  background:rgba(240,192,64,0.05);
  border-bottom:1px solid var(--border);
  font-size:13px; font-weight:700; color:var(--gold);
  display:flex; align-items:center; gap:8px;
}
.summary-body { padding:4px 0; }
.s-row {
  display:flex; justify-content:space-between; align-items:center;
  padding:10px 16px; font-size:13px;
}
.s-row .s-label { color:var(--muted); }
.s-row .s-val { font-weight:600; }
.s-divider { height:1px; background:var(--border); margin:4px 16px; }
.s-total {
  display:flex; justify-content:space-between; align-items:center;
  padding:14px 16px; font-size:16px; font-weight:900;
  border-top:1px solid var(--border);
}
.s-total .s-total-val { color:var(--gold); font-size:20px; }

/* ========= BUTTONS ========= */
.btn-wrap { padding:0 16px; margin-top:12px; display:flex; flex-direction:column; gap:8px; }

.btn {
  width:100%; padding:16px; border:none; border-radius:var(--radius);
  font-size:15px; font-weight:800; font-family:'Tajawal',sans-serif;
  cursor:pointer; transition:all .2s; display:flex; align-items:center; justify-content:center; gap:8px;
}
.btn:active { transform:scale(.97); }
.btn-primary {
  background:linear-gradient(135deg, #FFD700, #F0A500);
  color:#1a1000;
  box-shadow:0 4px 20px rgba(240,192,64,0.3);
}
.btn-primary:hover { box-shadow:0 6px 28px rgba(240,192,64,0.4); }
.btn-primary:disabled { opacity:.35; cursor:not-allowed; transform:none; box-shadow:none; }
.btn-ghost {
  background:rgba(255,255,255,0.05);
  color:var(--muted);
  border:1px solid var(--border);
}

/* ========= ABOUT ========= */
.about-hero {
  margin:20px 16px 0;
  background:linear-gradient(135deg, rgba(240,192,64,0.08), rgba(139,92,246,0.05));
  border:1px solid rgba(240,192,64,0.15);
  border-radius:22px; padding:28px 20px; text-align:center;
}
.about-hero .alogo { font-size:52px; margin-bottom:12px; }
.about-hero h2 {
  font-size:22px; font-weight:900;
  background:linear-gradient(135deg,#FFD700,#FF8C00);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  margin-bottom:8px;
}
.about-hero p { font-size:13px; color:var(--muted); line-height:1.7; }

.stats-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:10px; padding:0 16px; margin-top:12px;
}
.stat-card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius-sm); padding:16px; text-align:center;
}
.stat-num { font-size:26px; font-weight:900; color:var(--gold); }
.stat-lbl { font-size:11px; color:var(--muted); margin-top:3px; }

.feat-list { padding:0 16px; display:flex; flex-direction:column; gap:8px; }
.feat-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius-sm); padding:14px;
  display:flex; align-items:center; gap:14px;
}
.feat-ic {
  width:42px; height:42px; border-radius:12px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center; font-size:20px;
}
.feat-title { font-size:14px; font-weight:700; margin-bottom:2px; }
.feat-desc { font-size:12px; color:var(--muted); }

/* ========= SUPPORT ========= */
.support-links { padding:0 16px; display:flex; flex-direction:column; gap:10px; }
a.support-card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius); padding:16px;
  display:flex; align-items:center; gap:14px;
  text-decoration:none; color:inherit;
  transition:all .2s;
}
a.support-card:active { transform:scale(.98); border-color:var(--border2); }
.s-icon {
  width:48px; height:48px; border-radius:14px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center; font-size:22px;
}
.s-title { font-size:15px; font-weight:700; margin-bottom:2px; }
.s-desc { font-size:12px; color:var(--muted); }
.s-arr { margin-right:auto; margin-left:0; color:var(--muted2); font-size:22px; font-weight:300; }

.faq-wrap { padding:0 16px; display:flex; flex-direction:column; gap:8px; }
.faq-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius-sm); overflow:hidden;
}
.faq-q {
  padding:15px 16px; font-size:14px; font-weight:600;
  cursor:pointer; display:flex; justify-content:space-between; align-items:center;
  user-select:none;
}
.faq-arr { color:var(--muted); transition:transform .25s; font-size:18px; flex-shrink:0; }
.faq-a {
  font-size:13px; color:var(--muted); line-height:1.65;
  max-height:0; overflow:hidden; transition:max-height .3s ease, padding .3s;
  padding:0 16px;
}
.faq-item.open .faq-arr { transform:rotate(180deg); color:var(--gold); }
.faq-item.open .faq-a { max-height:200px; padding:0 16px 16px; }
.faq-item.open .faq-q { color:var(--gold); }

/* ========= TOAST ========= */
.toast {
  position:fixed; bottom:100px; left:50%;
  transform:translateX(-50%) translateY(20px);
  background:rgba(30,30,50,0.95); backdrop-filter:blur(10px);
  border:1px solid var(--border); border-radius:30px;
  padding:10px 22px; font-size:13px; font-weight:600;
  white-space:nowrap; z-index:999; pointer-events:none;
  opacity:0; transition:all .3s; box-shadow:0 8px 24px rgba(0,0,0,0.4);
}
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

/* ========= LOADING ========= */
.page-pad { padding-bottom: 12px; }
</style>
</head>
