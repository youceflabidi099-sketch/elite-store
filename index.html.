    <span class="ni">💬</span><span>الدعم</span>
  </button>
</nav>

<div class="toast" id="toast"></div>

<script>
const tg = window.Telegram?.WebApp;
if (tg) { tg.ready(); tg.expand(); }

// ===== PACKAGES DATA =====
const PKGS = [
  {
    name: "باقة 100 نجمة", icon: "⭐",
    price: "500 دج", old: "700 دج", save: "توفير 29%",
    desc: "مثالية للبداية", badge: null,
    color: "rgba(250,204,21,.08)"
  },
  {
    name: "باقة 250 نجمة", icon: "⭐",
    price: "1,000 دج", old: "1,500 دج", save: "توفير 33%",
    desc: "الأكثر مبيعاً", badge: {text:"🔥 الأكثر طلباً", cls:"badge-hot"},
    color: "rgba(255,100,80,.06)"
  },
  {
    name: "باقة 500 نجمة", icon: "💫",
    price: "1,800 دج", old: "2,500 دج", save: "توفير 28%",
    desc: "قيمة ممتازة للمحترفين", badge: null,
    color: "rgba(96,165,250,.06)"
  },
  {
    name: "باقة 1000 نجمة", icon: "💎",
    price: "3,200 دج", old: "5,000 دج", save: "توفير 36%",
    desc: "للاستخدام المكثف", badge: {text:"👑 الأفضل قيمة", cls:"badge-best"},
    color: "rgba(240,192,64,.07)"
  },
  {
    name: "VIP شهري كامل", icon: "👑",
    price: "5,000 دج", old: null, save: null,
    desc: "وصول كامل لجميع المزايا الحصرية", badge: {text:"💎 VIP", cls:"badge-vip"},
    color: "rgba(139,92,246,.08)"
  },
];

let selected = null;

// ===== RENDER PACKAGES =====
const list = document.getElementById('pkg-list');
PKGS.forEach((p, i) => {
  const el = document.createElement('div');
  el.className = 'pkg-card';
  el.style.background = p.color;
  el.innerHTML = `
    ${p.badge ? `<div class="pkg-badge ${p.badge.cls}">${p.badge.text}</div>` : ''}
    <div class="pkg-icon-wrap">${p.icon}</div>
    <div class="pkg-info" style="${p.badge ? 'margin-top:10px' : ''}">
      <div class="pkg-name">${p.name}</div>
      <div class="pkg-desc">${p.desc}</div>
    </div>
    <div class="pkg-right" style="${p.badge ? 'margin-top:10px' : ''}">
      ${p.old ? `<div class="pkg-old">${p.old}</div>` : ''}
      <div class="pkg-price">${p.price}</div>
      ${p.save ? `<div class="pkg-save">${p.save}</div>` : ''}
    </div>
    <div class="pkg-check">✓</div>
  `;
  el.onclick = () => selectPkg(el, p);
  list.appendChild(el);
});

function selectPkg(el, pkg) {
  document.querySelectorAll('.pkg-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  selected = pkg;
  document.getElementById('s-name').textContent = pkg.name;
  document.getElementById('s-price').textContent = pkg.price;
  document.getElementById('order-area').style.display = 'block';
  document.getElementById('hint-btn').style.display = 'none';
  el.scrollIntoView({ behavior:'smooth', block:'nearest' });
  tg?.HapticFeedback?.impactOccurred('medium');
}

function resetSel() {
  document.querySelectorAll('.pkg-card').forEach(c => c.classList.remove('selected'));
  selected = null;
  document.getElementById('order-area').style.display = 'none';
  document.getElementById('hint-btn').style.display = 'block';
  tg?.HapticFeedback?.impactOccurred('light');
}

function sendOrder() {
  if (!selected) return;
  if (tg) {
    tg.sendData(JSON.stringify({ item: selected.name, price: selected.price }));
  } else {
    showToast('✅ تم إرسال الطلب بنجاح!');
  }
  tg?.HapticFeedback?.notificationOccurred('success');
}

// ===== NAVIGATION =====
function goTo(page, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('pg-' + page).classList.add('active');
  btn.classList.add('active');
  window.scrollTo({ top:0, behavior:'smooth' });
  tg?.HapticFeedback?.selectionChanged();
}

// ===== TOAST =====
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}
</script>
</body>
